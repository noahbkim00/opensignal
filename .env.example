# Database (Neon)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Auth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for user sign-in + Sheets access)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub (server-side credential for fetching public repository issues)
# GitHub user OAuth is intentionally not required because OpenSignal only
# reads public repos; this token avoids unauthenticated API rate limits.
GITHUB_TOKEN=your-github-token-for-public-issue-reads

# Token encryption (32 bytes, base64 encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# Vercel Cron secret (protect cron endpoint)
CRON_SECRET=your-cron-secret-here
